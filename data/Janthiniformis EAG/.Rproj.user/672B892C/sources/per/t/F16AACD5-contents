```{r pull_data}
depol_data <- 
  read_excel("depolarizations.xlsx",
             sheet = "compound response") %>%
  dplyr::select(species, plant, compound, run1:run5) 
```

Compound responses

```{r}
<<pull_data>>
depol_data_plot <-
depol_data %>%
  pivot_longer(-c(species, plant, compound),
               names_to = "run",
               values_to = "mv") %>%
  group_by(species, plant, compound) %>%
  mutate(sd = sd(mv),
         mean_mv = mean(mv),
         n = n(),
         se = sd/sqrt(n)) %>%
  dplyr::select(-run, -mv) %>% 
  distinct() %>%
  na.omit() %>%
  filter(plant != "test")

depol_data_plot$plant <- factor(depol_data_plot$plant, 
                                levels = c("dt","yt",
                                           "d6y6", "y6d6",
                                           "hbr", "rad"))

depol_data_plot %>%
  mutate(species = factor(species, levels = c("janthinus", "janthiniformis"))) %>%
  ggplot() +
  geom_bar(aes(x = compound, y = mean_mv,
               fill = plant),
           color = "black",
           linewidth = 0.3,
           alpha = 0.8,
           stat = "identity",
           position = position_dodge()) +
  geom_errorbar(aes(x = compound, 
                    ymin = mean_mv - se,
                    ymax = mean_mv + se,
                    group = plant),
                position = position_dodge(width = 0.9),
                width = 0.5,
                linewidth = 0.5) +
  theme_bw() +
  labs(x = NULL,
       y = "Mean depolarization repsonse (mV)",
       fill = NULL) +
  scale_x_discrete(
    labels = c(
      "z3hex" = expression(italic("Z") * "-3-hexenyl acetate"),
      "cocimene" = expression("Cis-" * beta * "-ocimene"),
      "tocimene" = expression("Trans-" * beta * "-ocimene"),
      "limonene" = expression(delta * "-limonene"),
      "linalool" = "Linalool",
      "sixmethyl" = "6-methyl-5-hepten-2-one",
      "caryophyllene" = "Caryophyllene")) +  
  scale_fill_discrete(
    # values = c("yt" = "#FBA60B",
    #            "dt" = "#1a6e29",
    #            "y6d6" = "#FDD488",
    #            "d6y6" = "#619B6B",
    #            "hbr" = "#9e6494",
    #            "rad" = "#153b81"),
    labels = c("dt" = "DT",
               "yt" = "YT",
               "d6y6" = "D6Y6",
               "y6d6" = "Y6D6",
               "hbr" = "HBR",
               "rad" = "RAD")) +
  theme(axis.text.x = element_text(angle = 25, hjust = 1),
        panel.grid = element_blank(),
        strip.text = element_text(face = "italic", size = 13)) +
    facet_wrap(~species, ncol = 1,
               labeller = labeller(species = c("janthinus" = "Mecinus janthinus",
                                               "janthiniformis" = "Mecinus janthiniformis"))) 
```
 
 
