# Pure EAD
```{r pure_ead_data}
ead_data <- 
  read_excel("depolarizations.xlsx",
             sheet = "EAD response") %>%
  dplyr::select(species, plant, concentration, run1:run5) 
```


Pure ead responses
```{r}
<<pure_ead_data>>
ead_data_plot <-
ead_data %>%
  pivot_longer(-c(species, plant, concentration),
               names_to = "run",
               values_to = "mv") %>%
  group_by(species, plant, concentration) %>%
  mutate(sd = sd(mv),
         mean_mv = mean(mv),
         n = n(),
         se = sd/sqrt(n)) %>%
  dplyr::select(-run, -mv) %>% 
  distinct() %>%
  na.omit() %>%
  filter(plant != "test") %>%
  mutate(species_conc = paste(species, concentration))

ead_data_plot$plant <- factor(ead_data_plot$plant, 
                                levels = c("dt","yt",
                                           "d6y6", "y6d6",
                                           "hbr", "rad"))

ead_data_plot %>%
  ggplot() +
  geom_bar(aes(x = plant, y = mean_mv,
               fill = species),
           stat = 'identity',
           position = position_dodge()) +
  geom_errorbar(aes(x = plant, 
                    ymin = mean_mv - se,
                    ymax = mean_mv + se,
                    group = species),
                position = position_dodge(width = 0.9),
                linewidth = 0.3,
                width = 0.2) +
  theme_bw() +
  theme(panel.grid = element_blank()) +
  facet_wrap(~concentration, ncol = 1)
```


