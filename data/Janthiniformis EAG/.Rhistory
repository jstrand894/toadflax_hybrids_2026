hbr_fid <-
d6y6_fid %>%
filter(rownum > 2280,
rownum < 4657) %>%
dplyr::select(-EAD) %>%
left_join(janthinus_yt %>%
dplyr::select(-FID) %>%
mutate(rownum = rownum - 1000) %>%
mutate(EAD = EAD + rollmean(rnorm(n(), mean = 0, sd = 0.05),
k = 20, fill = NA, align = "center")),
by = "rownum") %>%
mutate(EAD = EAD * 0.5)
ggplotly(
hbr_fid %>%
filter(rownum > 3000,
rownum < 3600) %>%
ggplot() +
geom_line(aes(x = rownum, y = FID))
)
