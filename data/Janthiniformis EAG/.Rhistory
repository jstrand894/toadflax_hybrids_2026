spike_data <- tribble(
~name,        ~start,  ~size,
"sixmethyl",    1775,   0.55,
"z3hex",        2009,   1.19,
"limonene",     2363,   0.591,
"tbocimene",    2497,   1.43,
"ocimene",      3168,   0.89,
"linalool",     4753,   1.38,
"caryophyllene",5262,   0.77) %>%
mutate(size = size + runif(n(), min = 0.4, max = 1.5))
spike_values <- c(0.183, 0.352, 0.588, 0.810, 0.865, 0.822, 0.678, 0.618)
combined_spike_table <- spike_data %>%
mutate(
spike_value = map2(size*.7, list(spike_values), ~ .y * .x),
rownum = map2(start, spike_value, ~ .x:(.x + length(.y) - 1)),
spike_table = pmap(list(rownum, spike_value, name), ~ tibble(rownum = ..1, spike_value = ..2, name = ..3))
) %>%
select(spike_table) %>%
unnest(cols = spike_table) %>%
rename("EAD" = "spike_value") %>%
dplyr::select(-3)
fid_line_spikes <-
fid_line %>%
dplyr::select(-FID) %>%
filter(!rownum %in% combined_spike_table$rownum) %>%
bind_rows(combined_spike_table %>%
mutate(EAD)) %>%
left_join(fid_line %>%
select(-EAD), by = "rownum")
ggplotly(
fid_line_spikes %>%
ggplot() +
geom_line(aes(x = rownum, y = EAD*-0.1)) +
geom_line(aes(x = rownum, y = FID)) +
ylim(min_y = -1.4,
max_y = 1.4) +
theme(axis.title.y = element_blank(),
axis.text.y = element_blank(),
axis.ticks.y = element_blank(),
axis.ticks.x = element_blank(),
axis.text.x = element_blank(),
panel.background = element_blank(),
plot.background = element_blank(),
panel.grid = element_blank())
)
library(ambient)
fid_line <-
dt_janthinus %>%
mutate(EAD = EAD + rollmean(rnorm(n(), mean = 0, sd = 0.3),
k = 20, fill = NA, align = "center")) %>%
mutate(rownum = row_number())
fid_line %>%
ggplot() +
geom_line(aes(x = rownum, y = -1*EAD)) +
ylim(min_y = -1.4,
max_y = 1.4)
